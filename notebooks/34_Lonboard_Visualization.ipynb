   "outputs": [],
   "source": [
    "min_bound = 5000\n",
    "max_bound = 50000\n",
    "normalized_download_speed = (gdf[\"avg_d_kbps\"] - min_bound) / (max_bound - min_bound)\n",
    "fill_color = apply_continuous_cmap(normalized_download_speed, BrBG_10)\n",
    "radius = normalized_download_speed * 1000"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 41,
   "id": "860c089f-ad79-4706-ab95-0876a5fd5f4e",
   "metadata": {},
   "outputs": [],
   "source": [
    "filter_values = np.column_stack(\n",
    "    [gdf[\"avg_d_kbps\"], gdf[\"avg_u_kbps\"], gdf[\"avg_lat_ms\"]],\n",
    ")\n",
    "initial_filter_range = [\n",
    "    [10_000, 50_000],\n",
    "    [1000, 10_000],\n",
    "    [0, 100],\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 42,
   "id": "8437f031-0d38-42f5-8398-d52e47e0fbbf",
   "metadata": {},
   "outputs": [],
   "source": [
    "sidecar = Sidecar(anchor=\"split-right\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 43,
   "id": "fbd27a28-e5ba-402c-8002-33b5eedd26f5",
