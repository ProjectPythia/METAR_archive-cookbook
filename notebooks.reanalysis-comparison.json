},"children":[{"type":"text","value":"In order to compare this to the METAR data, we’ll need to do some conversions. The function ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"SD5Pz6efmg"},{"type":"inlineCode","value":"aorc_to_metar_cols","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"FJYcm7ca6a"},{"type":"text","value":" does this below.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"I1LPXsbTX5"}],"key":"OcDLPzwbH3"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":23,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Temperature K --> Temperature C","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"cbcgPZMZtn"}],"key":"UtrnGOmf72"}],"key":"EVJwCYlZ37"},{"type":"listItem","spread":true,"position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Specific humidity --> Relative humidity","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"VmvF8vxJQn"}],"key":"wOSqd0f2gs"}],"key":"i6WR6nOzlV"},{"type":"listItem","spread":true,"position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"U/V wind speeds (m/s) --> Wind direction (deg) and wind speed (knots)","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"SsDPiDLkw7"}],"key":"FQ9oj2CcCp"}],"key":"Y2AxwoWYNM"}],"key":"Bl14Cpk0Vp"}],"key":"SamRrYiyPK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def aorc_to_metar_cols(df_aorc): \n    '''\n    '''\n    for col in target_vars: \n        if col == 'tmpc' : \n            print('Converting TMP_2maboveground in K to tmpc in C') \n            # df_aorc.rename('TMP_2maboveground', 'tmpc') \n            df_aorc['tmpc'] = df_aorc['TMP_2maboveground'] - 273\n        if col == 'relh' : \n            print('Converting SPFH_2maboveground to relh (%)') \n            q = df_aorc['SPFH_2maboveground']\n            tmp = df_aorc['tmpc']\n            prs = df_aorc['PRES_surface']\n            df_aorc['relh'] = spech_to_relh(q, tmp, prs)\n        if col == 'drct' : \n            print('Converting UGRD_10maboveground and VGRD_10maboveground to wind direction (deg)') \n            dir_rad = np.arctan2(df_aorc['UGRD_10maboveground'], df_aorc['VGRD_10maboveground'])\n            dir_deg = np.degrees(dir_rad) + 180.0\n            \n            # Ensure all angles fall strictly between 0 and 360 degrees (e.g., handles negative angles smoothly)\n            df_aorc['drct'] = np.mod(dir_deg, 360.0)  \n        if col == 'sknt' : \n            print('Converting UGRD_10maboveground and VGRD_10maboveground to wind speed (knots)') \n            speed_mps = np.hypot(df_aorc['UGRD_10maboveground'], df_aorc['VGRD_10maboveground'])\n            df_aorc['sknt'] = speed_mps * 1.94384\n            \n            \n            # df_aorc['relh'] = (tmp.dims, rh_vals)\n        \n    return df_aorc\n\ndef spech_to_relh(q, tmp, prs): \n    p_hpa = prs / 100.0\n\n    # 3. Step-by-step vectorized calculation\n    # Calculate mixing ratio (w)\n    w = q / (1.0 - q)\n    \n    # Calculate saturation vapor pressure (es) in hPa via Bolton (1980)\n    es = 6.112 * np.exp((17.67 * tmp) / (tmp + 243.5))\n    \n    # Calculate saturation mixing ratio (ws)\n    epsilon = 0.62198\n    ws = epsilon * es / (p_hpa - es)\n    \n    # Calculate Relative Humidity (%) bounded logically between 0% and 100%\n    rh_array = (w / ws) * 100.0\n    rh_array = np.clip(rh_array, 0.0, 100.0)\n    return rh_array","key":"GXCPI3rwF0"},{"type":"outputs","id":"4-CooIJdi7mkeSfIF7AH2","children":[],"key":"uJFZpm4ZX2"}],"key":"euI3EZGznt"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"AORC data is hosted in Zarr format by NOAA on a public S3 bucket.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jvzlrANWVq"}],"key":"cjavVikEU3"}],"key":"gqEmnXF2gm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"aorc_base = \"noaa-nws-aorc-v1-1-1km\" \naorc_urls = [f\"s3://{aorc_base}/{y}.zarr\" for y in range(time_start.year, time_end.year + 1)]\naorc_urls","key":"wunXLAqKI5"},{"type":"outputs","id":"xjvP_WWf8JNGZ7DcSNUpF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":11,"metadata":{},"data":{"text/plain":{"content":"['s3://noaa-nws-aorc-v1-1-1km/2021.zarr']","content_type":"text/plain"}}},"key":"OcV3Kcvac7"}],"key":"sTgKkbxmOX"}],"key":"U0iNHtQ3Wh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"s3_out = s3fs.S3FileSystem(anon=True)\nfileset_aorc = [\n    s3fs.S3Map(root=url, s3=s3_out, check=False)\n    for url in aorc_urls\n]\n\ndf_aorc = xr.open_mfdataset(fileset_aorc, engine='zarr')","key":"QcaCATwa1Z"},{"type":"outputs","id":"zDTdU5Awf1uTYihEZvBbR","children":[],"key":"CxnmDQnxrk"}],"key":"KMotavjySf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# df_aorc = df_aorc.rename({'latitude': 'y', 'longitude': 'x'})","key":"XiU5G0sDEs"},{"type":"outputs","id":"gEGyaon2LRu4v5bZrqGgB","children":[],"key":"sswH3YKacQ"}],"key":"bmHApYixVJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# find the nearest point in the AORC grid \nlat_idx = np.abs(df_aorc.latitude.values - target[0]).argmin()\nlon_idx = np.abs(df_aorc