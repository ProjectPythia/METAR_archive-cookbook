e":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"In plain language, this means that Parquet is a modern, performant alternative to the plain text CSV (Comma Separated Variables) format. The following code cell pulls in some example CSV-formatted data from the ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"FHKZ9xHaSU"},{"type":"link","url":"https://mesonet.agron.iastate.edu/","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Iowa Environmental Mesonet","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"ju8Mikpsii"}],"urlSource":"https://mesonet.agron.iastate.edu/","key":"Ngc7UZjoar"},{"type":"text","value":" (IEM) and contains the following fields: station (Denver International Airport), day (Jan 1-10, 2026), and max recorded temperature in Fahrenheit.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"P89FXYMFSY"}],"key":"VpyQNjCWyz"}],"key":"JJfkkyDa3Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import requests\n\niem_url = \"https://mesonet.agron.iastate.edu/cgi-bin/request/daily.py\"\nparams = {\n    \"network\": \"CO_ASOS\", \"stations\": \"DEN\",\n    \"year1\": \"2026\", \"month1\": \"1\", \"day1\": \"1\",\n    \"year2\": \"2026\", \"month2\": \"1\", \"day2\": \"10\",\n    \"var\": \"max_temp_f\",\n    \"na\": \"blank\",\n    \"format\": \"csv\"\n}\nden_data = requests.get(\n    iem_url,\n    params=params\n)\nprint(den_data.content.decode())","key":"suW5LiTDMb"},{"type":"outputs","id":"3RuTvdMgjTO4955rUYNkW","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"station,day,max_temp_f\nDEN,2026-01-01,64.0\nDEN,2026-01-02,60.0\nDEN,2026-01-03,64.0\nDEN,2026-01-04,67.0\nDEN,2026-01-05,61.0\nDEN,2026-01-06,57.0\nDEN,2026-01-07,58.0\nDEN,2026-01-08,41.0\nDEN,2026-01-09,32.